# Supabase -> Project Settings -> API -> Project URL (no trailing slash)
SUPABASE_URL=

# Supabase -> Project Settings -> API -> service_role key (backend only, keep secret)
SUPABASE_SERVICE_KEY=

# DeepSeek Console -> platform.deepseek.com -> API Keys
DEEPSEEK_API_KEY=

# Google AI Studio -> API keys
GEMINI_API_KEY=

# Google Cloud Console -> YouTube Data API v3 -> Credentials -> API Key
YOUTUBE_API_KEY=

# Number of videos to fetch per run (default: 20 in production)
# MAX_RESULTS=50  # uncomment for local backfill
